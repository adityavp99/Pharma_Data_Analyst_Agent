# Choose one provider: azure_openai, openai, or openrouter.
LLM_PROVIDER=azure_openai

# Company Azure OpenAI endpoint through the internal gateway.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://genaiapimna.jnj.com/openai-chat
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Public OpenAI fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PLANNER_MODEL=gpt-4.1-mini

# OpenRouter fallback.
OPENROUTER_API_KEY=
OPENROUTER_PLANNER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=LangChain Agentic CSV Analyst

# Agent runtime settings.
AGENT_RECURSION_LIMIT=12
AGENT_MAX_SQL_ROWS=1000
AGENT_ENABLE_PYTHON_TOOL=true
