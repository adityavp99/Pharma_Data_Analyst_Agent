OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_PROVIDER=openai
OPENAI_PLANNER_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# Enterprise/custom OpenAI-compatible direct chat-completions endpoint.
# Use when your org gives you a full deployment URL and an `api-key` header.
# LLM_PROVIDER=custom_openai
CUSTOM_OPENAI_CHAT_URL=
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_API_KEY_HEADER=api-key
CUSTOM_OPENAI_PLANNER_MODEL=
CUSTOM_OPENAI_VISION_MODEL=
CUSTOM_OPENAI_MAX_TOKENS=1500

PHARMA_DB_PATH=data/processed/pharma_mvp.db
MAX_SQL_ROWS=200
AI_SUMMARY_PROVIDER=
OPENROUTER_API_KEY=
OPENROUTER_SUMMARY_MODEL=deepseek/deepseek-v4-flash:free
ENABLE_LLM_PLANNER=true
OPENROUTER_PLANNER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_VISION_MODEL=deepseek/deepseek-v4-flash:free
